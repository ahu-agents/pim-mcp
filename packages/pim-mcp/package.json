{
  "name": "pim-mcp",
  "version": "0.1.0",
  "description": "Unified MCP server for mail, calendar, and CalDAV VTODO reminders",
  "keywords": ["mcp", "pim", "email", "calendar", "tasks", "caldav", "imap", "smtp"],
  "license": "MIT",
  "repository": {
    "type": "git",

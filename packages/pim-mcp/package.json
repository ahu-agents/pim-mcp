    "directory": "packages/pim-mcp"
  },
  "homepage": "https://github.com/ahu-agents/pim-mcp",
  "bugs": "https://github.com/ahu-agents/pim-mcp/issues",
  "type": "module",
  "bin": {
    "pim-mcp": "dist/bin/cli.js"
  },
  "main": "dist/main.js",
